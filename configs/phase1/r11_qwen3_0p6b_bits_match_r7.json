{
  "run_id": "R11",
  "phase": "phase1_repair",
  "description": "Equal-budget bits-only baseline matched to R7 by upgrading selected RTN layers from 4-bit to 8-bit.",
  "model": {
    "name": "Qwen/Qwen3-0.6B-Base",
    "tokenizer_name": "Qwen/Qwen3-0.6B-Base",
    "dtype_preference": [
      "bfloat16",
      "float16"
    ]
  },
  "method": {
    "name": "mixed_precision_budget_match",
    "base_run_id": "R2",
    "base_method": "rtn",
    "base_bit_width": 4,
    "target_bit_width": 8,
    "memory_match_run_id": "R7",
    "selected_layers_source": "results/phase1/R2/layer_errors.json",
    "selected_layers_top_k": 8,
    "factor_dtype_bytes": 2
  },
  "calibration": {
    "dataset": "wikitext",
    "subset": "wikitext-2-raw-v1",
    "split": "train",
    "num_sequences": 128,
    "sequence_length": 512,
    "sampling": "seeded_shuffle",
    "seed": 42
  },
  "evaluation": {
    "dataset": "wikitext",
    "subset": "wikitext-2-raw-v1",
    "split": "test",
    "sequence_length": 512,
    "stride": 512,
    "metrics": [
      "perplexity",
      "latency_ms_per_token",
      "memory_total_bytes",
      "layerwise_weight_error",
      "layerwise_activation_error"
    ]
  },
  "profiling": {
    "layerwise_weight_error": true,
    "layerwise_activation_error": true,
    "residual_svd_profile": false,
    "profile_sequence_length": 128,
    "profile_num_sequences": 8,
    "residual_top_k_layers": 8,
    "candidate_ranks": [
      4,
      8,
      16,
      32
    ]
  },
  "outputs": {
    "results_dir": "results/phase1/R11",
    "metrics_file": "metrics.json",
    "layer_summary_file": "layer_errors.json",
    "residual_profile_file": "residual_profiles.json"
  }
}
