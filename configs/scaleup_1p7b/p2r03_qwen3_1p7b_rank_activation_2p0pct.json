{
  "run_id": "P2R03_Q17B",
  "phase": "qwen3_1p7b_transfer",
  "description": "Qwen/Qwen3-1.7B-Base targeted-rank allocator using activation-space sensitivity at +2.0% of R2_Q17B memory.",
  "model": {
    "name": "Qwen/Qwen3-1.7B-Base",
    "tokenizer_name": "Qwen/Qwen3-1.7B-Base",
    "dtype_preference": [
      "bfloat16",
      "float16"
    ]
  },
  "method": {
    "name": "targeted_svd_rank",
    "base_run_id": "R2_Q17B",
    "base_method": "rtn",
    "base_bit_width": 4,
    "target_granularity": "matrix",
    "allocator": "greedy_activation",
    "proxy_family": "activation",
    "candidate_pool_path": "configs/scaleup_1p7b/qwen3_1p7b_r2_top12_candidate_pool.json",
    "budget_percent_of_base": 2.0,
    "budget_reference_metric": "memory_total_bytes",
    "candidate_ranks": [
      4,
      8,
      16,
      32
    ],
    "factor_dtype_bytes": 2
  },
  "calibration": {
    "dataset": "wikitext",
    "subset": "wikitext-2-raw-v1",
    "split": "train",
    "num_sequences": 128,
    "sequence_length": 512,
    "sampling": "seeded_shuffle",
    "seed": 42
  },
  "evaluation": {
    "dataset": "wikitext",
    "subset": "wikitext-2-raw-v1",
    "split": "test",
    "sequence_length": 512,
    "stride": 512,
    "metrics": [
      "perplexity",
      "latency_ms_per_token",
      "memory_total_bytes",
      "allocation_actions"
    ]
  },
  "profiling": {
    "layerwise_weight_error": true,
    "layerwise_activation_error": true,
    "residual_svd_profile": false,
    "profile_sequence_length": 128,
    "profile_num_sequences": 8
  },
  "outputs": {
    "results_dir": "results/qwen3_1p7b/P2R03",
    "metrics_file": "metrics.json",
    "layer_summary_file": "layer_errors.json",
    "residual_profile_file": "residual_profiles.json"
  }
}
