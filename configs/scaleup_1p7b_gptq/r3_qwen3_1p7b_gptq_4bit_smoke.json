{
  "run_id": "R3S_Q17B",
  "phase": "qwen3_1p7b_gptq_smoke",
  "description": "Small GPTQ smoke baseline for Qwen/Qwen3-1.7B-Base on Modal to validate numerics and artifact persistence.",
  "model": {
    "name": "Qwen/Qwen3-1.7B-Base",
    "tokenizer_name": "Qwen/Qwen3-1.7B-Base",
    "dtype_preference": [
      "float16"
    ]
  },
  "method": {
    "name": "gptq",
    "quantizer": "GPTQ",
    "bit_width": 4,
    "group_size": 128,
    "symmetric": true,
    "damp_percent": 0.1,
    "desc_act": false,
    "act_group_aware": true,
    "true_sequential": true,
    "batch_size": 1
  },
  "calibration": {
    "dataset": "wikitext",
    "subset": "wikitext-2-raw-v1",
    "split": "train",
    "num_sequences": 16,
    "num_text_samples": 16,
    "sequence_length": 512,
    "sampling": "seeded_shuffle",
    "seed": 42
  },
  "evaluation": {
    "dataset": "wikitext",
    "subset": "wikitext-2-raw-v1",
    "split": "test",
    "sequence_length": 512,
    "stride": 512,
    "num_sequences": 16,
    "metrics": [
      "perplexity",
      "latency_ms_per_token",
      "memory_total_bytes",
      "layerwise_weight_error"
    ]
  },
  "profiling": {
    "layerwise_weight_error": true,
    "layerwise_activation_error": false,
    "residual_svd_profile": false,
    "profile_sequence_length": 128,
    "profile_num_sequences": 0,
    "residual_top_k_layers": 0,
    "candidate_ranks": [
      4,
      8,
      16,
      32
    ]
  },
  "outputs": {
    "results_dir": "results/modal/qwen3_1p7b_gptq_smoke/R3S_Q17B",
    "metrics_file": "metrics.json",
    "layer_summary_file": "layer_errors.json",
    "residual_profile_file": "residual_profiles.json"
  }
}
