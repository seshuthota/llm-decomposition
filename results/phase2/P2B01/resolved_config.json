{
  "calibration": {
    "dataset": "wikitext",
    "num_sequences": 128,
    "sampling": "seeded_shuffle",
    "seed": 42,
    "sequence_length": 512,
    "split": "train",
    "subset": "wikitext-2-raw-v1"
  },
  "description": "Phase-2 first-pass matrix-level bits-only baseline with a uniform action policy at +0.25% of R2 memory.",
  "evaluation": {
    "dataset": "wikitext",
    "metrics": [
      "perplexity",
      "latency_ms_per_token",
      "memory_total_bytes",
      "allocation_actions"
    ],
    "sequence_length": 512,
    "split": "test",
    "stride": 512,
    "subset": "wikitext-2-raw-v1"
  },
  "method": {
    "allocator": "uniform_bits",
    "base_bit_width": 4,
    "base_method": "rtn",
    "base_run_id": "R2",
    "budget_percent_of_base": 0.25,
    "budget_reference_metric": "memory_total_bytes",
    "candidate_pool_path": "configs/phase2/qwen3_0p6b_r2_top12_candidate_pool.json",
    "name": "targeted_mixed_precision",
    "proxy_family": "activation",
    "target_granularity": "matrix"
  },
  "model": {
    "dtype_preference": [
      "bfloat16",
      "float16"
    ],
    "name": "Qwen/Qwen3-0.6B-Base",
    "tokenizer_name": "Qwen/Qwen3-0.6B-Base"
  },
  "outputs": {
    "layer_summary_file": "layer_errors.json",
    "metrics_file": "metrics.json",
    "residual_profile_file": "residual_profiles.json",
    "results_dir": "results/phase2/P2B01"
  },
  "phase": "phase2",
  "profiling": {
    "layerwise_activation_error": true,
    "layerwise_weight_error": true,
    "profile_num_sequences": 8,
    "profile_sequence_length": 128,
    "residual_svd_profile": false
  },
  "run_id": "P2B01"
}
